---
const categories = [
    {
        name: 'Departamentos',
        displayName: 'Departamentos',
        image: '/img/categories/departamentos.png',
        href: '/buscar?categoria=Departamentos',
        width: 'full'
    },
    {
        name: 'Edificios a Estrenar',
        displayName: 'Edificios a<br/>Estrenar',
        image: '/img/categories/edificios.png',
        href: '/buscar?categoria=Edificios a Estrenar',
        width: 'full'
    },
    {
        name: 'Casas / Chalets',
        displayName: 'Casas<br/>Chalets',
        image: '/img/categories/casas.png',
        href: '/buscar?categoria=Casas / Chalets',
        width: 'full'
    },
    {
        name: 'Duplex / PH',
        displayName: 'Duplex<br/>PH',
        image: '/img/categories/duplex.png',
        href: '/buscar?categoria=PH / Duplex',
        width: 'full'
    },
    {
        name: 'Venta en Pozo',
        displayName: 'Venta en<br/>Pozo',
        image: '/img/categories/en-pozo-blueprint-final.jpg',
        href: '/buscar?operacion=Venta en Pozo',
        width: 'narrow'
    }
];
---

<section class="snap-section bg-[#003B5C] py-16 overflow-visible w-full">
    <div class="max-w-[90rem] mx-auto px-4 sm:px-6 lg:px-8">
        <h3 class="text-3xl font-extrabold text-white mb-6 text-center">
            Propiedades en Venta en Mar del Plata
        </h3>
        
        <div class="flex flex-col md:flex-row items-center justify-center mt-6 mb-16 px-4">
            {categories.map((cat, i) => (
                <div 
                    class={`
                        relative transition-all duration-500 ease-in-out md:-ml-12 lg:-ml-16 first:ml-0 hover:!z-50
                        group w-full h-[29rem]
                        ${cat.width === 'narrow' ? 'md:w-[16rem] lg:w-[19.5rem]' : 'md:w-[21rem] lg:w-[24.5rem]'}
                    `}
                    style={`z-index: ${categories.length - i};`}
                >
                    <a 
                        href={cat.href}
                        class="block w-full h-full rounded-2xl overflow-hidden shadow-2xl border-[5px] border-white transition-all duration-500 ease-out hover:shadow-[0_50px_100px_-20px_rgba(0,0,0,0.5)] hover:-translate-y-16"
                    >
                        <img 
                            src={cat.name === 'Venta en Pozo' ? '/img/categories/en-pozo-blueprint-final.jpg' : cat.image} 
                            alt={cat.name}
                            class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
                        />
                        
                        <!-- Gradiente solo en la base para el botón (muy corto para no quitar brillo) -->
                        <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/80 to-transparent"></div>
                        
                        <!-- Contenedor del Título (Ubicado en el cuarto superior) -->
                        <div class={`absolute inset-0 flex flex-col items-center justify-start pt-16 text-center pointer-events-none bg-[radial-gradient(circle_at_50%_25%,rgba(0,0,0,0.5)_0%,rgba(0,0,0,0)_70%)] ${cat.name === 'Venta en Pozo' ? 'translate-x-4' : ''}`}>
                            <h4 class="text-xl lg:text-2xl font-black text-[#F5F5F1] leading-[1.1] tracking-wider uppercase title-shadow min-h-[2.2em] flex items-center justify-center" set:html={cat.displayName}>
                            </h4>
                        </div>

                        <!-- Botón centrado en la tarjeta -->
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                            <div class="transform scale-90 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-500">
                                <span class="inline-block bg-[#003B5C] text-white text-[10px] font-black py-3 px-8 rounded-full shadow-2xl uppercase tracking-widest border-2 border-[#D4AF37]">
                                    Explorar catálogo
                                </span>
                            </div>
                        </div>
                    </a>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .title-shadow {
        /* Sombra estilo "Glow" oscuro para separar del fondo sin que se vea un borde */
        text-shadow: 
            0px 0px 10px rgba(0,0,0,0.9),
            0px 0px 20px rgba(0,0,0,0.5);
    }
    /* El z-index se maneja dinámicamente para que la de la izquierda pise a la derecha */
</style>
