---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Página no encontrada">
    <div class="max-w-7xl mx-auto px-4 py-32 text-center">
        <h1 class="text-6xl font-extrabold text-indigo-900 mb-4">404</h1>
        <p class="text-xl text-gray-500 mb-8">Lo sentimos, la página que buscas no existe.</p>
        <a href="/" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
            Volver al inicio
        </a>
    </div>
</MainLayout>
