---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PropertyForm from '../../../components/islands/PropertyForm.svelte';

const { id } = Astro.params;
---

<AdminLayout title={`Editar Propiedad ${id}`}>
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Editar Propiedad</h1>
        <p class="text-sm text-gray-500">ID: {id}</p>
    </div>

    <div class="bg-white p-6 rounded-lg shadow">
        <PropertyForm id={id} client:load />
    </div>
</AdminLayout>
