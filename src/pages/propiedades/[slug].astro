---
import MainLayout from '../../layouts/MainLayout.astro';
import { supabase } from '../../lib/server/supabase';
import { InmuebleDTOSchema } from '../../schemas/inmuebles';

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect('/404');
}

// 1. Fetch property by slug
const { data: rawProperty, error } = await supabase
    .from('propiedades')
    .select('*')
    .eq('slug', slug)
    .single();

if (error || !rawProperty) {
    return Astro.redirect('/404');
}

// 2. Validate/Transform data
const propertyResult = InmuebleDTOSchema.safeParse(rawProperty);
if (!propertyResult.success) {
    console.error("Validation error for property detail:", propertyResult.error);
    return Astro.redirect('/500');
}

const property = propertyResult.data;

// Visual Formatting
const currencyFormatter = new Intl.NumberFormat('es-AR', {
    style: 'currency',
    currency: property.moneda || 'USD',
    maximumFractionDigits: 0
});
const formattedPrice = currencyFormatter.format(property.precio);

const bucketUrl = "https://tgdupajzsaoznnraqouj.supabase.co/storage/v1/object/public/fotos-videos-inmo/";
---

<MainLayout title={property.titulo}>
    <div class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
        <!-- Breadcrumbs / Back -->
        <nav class="mb-8">
            <a href="/" class="text-indigo-600 hover:text-indigo-800 font-medium flex items-center gap-2">
                &lsaquo; Volver al listado
            </a>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <!-- Left Column: Gallery -->
            <div class="space-y-6">
                {property.fotos_nombres && property.fotos_nombres.length > 0 ? (
                    <div class="grid grid-cols-1 gap-4">
                        <!-- Main Image -->
                        <div class="aspect-video rounded-2xl overflow-hidden bg-gray-100 shadow-lg">
                            <img 
                                src={`${bucketUrl}${property.fotos_nombres[0]}`} 
                                alt={property.titulo}
                                class="w-full h-full object-cover"
                            />
                        </div>
                        
                        <!-- Grid Thumbnails (If more than 1) -->
                        {property.fotos_nombres.length > 1 && (
                            <div class="grid grid-cols-3 sm:grid-cols-4 gap-4">
                                {property.fotos_nombres.slice(1).map((foto) => (
                                    <div class="aspect-square rounded-xl overflow-hidden bg-gray-100 border border-gray-200">
                                        {foto.toLowerCase().endsWith('.mp4') || foto.toLowerCase().endsWith('.webm') ? (
                                            <video src={`${bucketUrl}${foto}`} class="w-full h-full object-cover" muted />
                                        ) : (
                                            <img src={`${bucketUrl}${foto}`} alt="Vista miniatura" class="w-full h-full object-cover hover:opacity-75 transition-opacity" />
                                        )}
                                    </div>
                                ))}
                            </div>
                        )}
                    </div>
                ) : (
                    <div class="aspect-video rounded-2xl bg-gray-50 flex items-center justify-center text-gray-400 border border-dashed border-gray-300">
                        <span class="text-lg">Sin imágenes disponibles</span>
                    </div>
                )}

                {property.video_360_url && (
                    <div class="pt-6">
                        <h3 class="text-xl font-bold text-gray-900 mb-4">Tour Virtual / Video 360</h3>
                        <div class="aspect-video rounded-2xl overflow-hidden bg-black shadow-lg">
                            <iframe src={property.video_360_url} class="w-full h-full" frameborder="0" allowfullscreen></iframe>
                        </div>
                    </div>
                )}
            </div>

            <!-- Right Column: Details -->
            <div class="flex flex-col">
                <div class="mb-6">
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-indigo-100 text-indigo-700 text-sm font-bold rounded-full uppercase tracking-wider">
                            {property.tipo_operacion}
                        </span>
                        <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm font-bold rounded-full uppercase tracking-wider">
                            {property.estado_propiedad}
                        </span>
                    </div>
                    <h1 class="mt-4 text-3xl sm:text-4xl font-extrabold text-[#003B5C] tracking-tight">
                        {property.titulo}
                    </h1>
                    <p class="mt-2 text-lg text-gray-500 flex items-center gap-2">
                        📍 {property.barrio || 'Ubicación no especificada'} | ID: {property.codigo || property.id.split('-')[0].toUpperCase()}
                    </p>
                </div>

                <div class="text-4xl font-bold text-indigo-600 mb-8 pb-8 border-b border-gray-200">
                    {formattedPrice}
                </div>

                <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-8">
                    {property.caracteristicas?.ambientes > 0 && (
                        <div class="bg-gray-50 p-4 rounded-xl border border-gray-100">
                             <span class="block text-xs text-gray-400 uppercase font-bold mb-1">Ambientes</span>
                             <span class="text-lg font-bold text-gray-800">{property.caracteristicas.ambientes}</span>
                        </div>
                    )}
                    {property.caracteristicas?.dormitorios > 0 && (
                        <div class="bg-gray-50 p-4 rounded-xl border border-gray-100">
                             <span class="block text-xs text-gray-400 uppercase font-bold mb-1">Habitaciones</span>
                             <span class="text-lg font-bold text-gray-800">{property.caracteristicas.dormitorios}</span>
                        </div>
                    )}
                    {property.caracteristicas?.banios > 0 && (
                        <div class="bg-gray-50 p-4 rounded-xl border border-gray-100">
                             <span class="block text-xs text-gray-400 uppercase font-bold mb-1">Baños</span>
                             <span class="text-lg font-bold text-gray-800">{property.caracteristicas.banios}</span>
                        </div>
                    )}
                    {property.caracteristicas?.superficie_total > 0 && (
                        <div class="bg-gray-50 p-4 rounded-xl border border-gray-100">
                             <span class="block text-xs text-gray-400 uppercase font-bold mb-1">Sup. Total</span>
                             <span class="text-lg font-bold text-gray-800">{property.caracteristicas.superficie_total} m²</span>
                        </div>
                    )}
                </div>

                <!-- Amenities Section -->
                <div class="mb-10">
                    <h3 class="text-xl font-bold text-gray-900 mb-4">Amenities y Características</h3>
                    <div class="flex flex-wrap gap-2">
                        {property.caracteristicas?.aire_acondicionado && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">❄️ Aire Acondicionado</span>}
                        {property.caracteristicas?.cochera && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🚗 Cochera</span>}
                        {property.caracteristicas?.gimnasio && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🏋️ Gimnasio</span>}
                        {property.caracteristicas?.lavadero && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🧺 Lavadero</span>}
                        {property.caracteristicas?.parrilla && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🔥 Parrilla</span>}
                        {property.caracteristicas?.patio && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🌳 Patio</span>}
                        {property.caracteristicas?.pileta && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🏊 Pileta</span>}
                        {property.caracteristicas?.quincho && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🥩 Quincho</span>}
                        {property.caracteristicas?.sala_de_juegos && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🕹️ Sala de juegos</span>}
                        {property.caracteristicas?.spa && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🧖 Spa</span>}
                        {property.caracteristicas?.sum && <span class="px-3 py-1 bg-blue-50 text-blue-700 text-sm rounded-lg border border-blue-100">🏢 SUM</span>}
                    </div>
                </div>

                <div class="prose prose-indigo max-w-none text-gray-600 mb-10">
                    <h3 class="text-xl font-bold text-gray-900 mb-4">Descripción</h3>
                    <p class="whitespace-pre-wrap leading-relaxed">
                        {property.descripcion || 'Sin descripción disponible.'}
                    </p>
                </div>

                <!-- CTAs -->
                <div class="mt-auto grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <button class="w-full py-4 px-6 bg-indigo-600 text-white font-bold rounded-xl hover:bg-indigo-700 transition-colors shadow-lg shadow-indigo-200">
                        Me interesa / Contactar
                    </button>
                    <button class="w-full py-4 px-6 bg-white text-indigo-600 font-bold rounded-xl border-2 border-indigo-600 hover:bg-indigo-50 transition-colors">
                        Compartir
                    </button>
                </div>
            </div>
        </div>
    </div>
</MainLayout>
